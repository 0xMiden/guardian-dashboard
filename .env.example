# Clerk authentication
# Get these from https://dashboard.clerk.com after creating a Clerk application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/select-endpoint
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/select-endpoint

# Guardian endpoints — JSON array, one object per Guardian server.
# Each user's allowed endpoint IDs and role are set in Clerk user public metadata.
# Never expose this env var to the client.
GUARDIAN_ENDPOINTS=[{"id":"testnet","label":"Guardian Testnet","url":"https://guardian.example.com","network":"MidenTestnet","commitment":"0x...","privateKey":"..."}]

# Optional — log streaming
DOCKER_CONTAINER_NAME=guardian-server-1
LOG_FILE_PATH=/var/log/guardian/guardian.log

# PostHog analytics — get your project token from posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
